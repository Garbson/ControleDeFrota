# ControleDeFrota — variáveis de ambiente
# Copie para .env e preencha os valores

# MySQL
MYSQL_ROOT_PASSWORD=rootSenhaForte123!
DB_USER=controlefrota_user
DB_PASS=senhaForteAqui456!

# JWT — gere com: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_UMA_CHAVE_LONGA_E_ALEATORIA
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_CHAVE_LONGA_E_ALEATORIA

# Frontend
VITE_API_URL=https://controlefrota.zlabs.com.br/api

# Cloudflare R2 — nunca versione os valores reais
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILES_BUCKET=controlefrota-files
R2_BACKUP_BUCKET=controlefrota-backups
BACKUP_ENABLED=false
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=35
